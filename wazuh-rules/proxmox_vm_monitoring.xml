<!--
  proxmox_vm_monitoring.xml
  Monitoraggio del ciclo di vita delle VM su Proxmox VE.
  Utile per audit di chi crea/distrugge risorse sull'hypervisor.
-->

<group name="proxmox,vm_lifecycle,">

  <!-- Creazione VM -->
  <rule id="100011" level="5">
    <decoded_as>proxmox-task</decoded_as>
    <field name="task">qmcreate</field>
    <description>Proxmox: VM creata (ID $(vmid)) da $(user)</description>
    <group>audit_change,</group>
  </rule>

  <!-- Distruzione VM -->
  <rule id="100012" level="7">
    <decoded_as>proxmox-task</decoded_as>
    <field name="task">qmdestroy</field>
    <description>Proxmox: VM distrutta (ID $(vmid)) da $(user)</description>
    <group>audit_change,</group>
    <mitre>
      <id>T1485</id>
    </mitre>
  </rule>

</group>
